  const protocolSteps = normalizeSteps(protocol.steps);
  const protocolBody = [
    protocol.dailyPractice,
    ...(protocol.turningQuestions ? ['전환 질문: ' + listify(protocol.turningQuestions).join(' / ')] : [])
  ].filter(Boolean);
  sections.push(makeSection('08', protocol.title || '재프로그래밍 프로토콜', {
