function escapeHtml(v){
  return String(v ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}
function isObj(v){ return v && typeof v === 'object' && !Array.isArray(v); }
function safeName(v){
  return String(v || 'client').trim()
    .replace(/[\\/:*?"<>|#%&{}$!'@+=`]/g,'')
    .replace(/\s+/g,'_') || 'client';
}
function dateDigits(v){
  return String(v || '').replace(/\D/g,'').slice(0,8) || new Date().toISOString().slice(0,10).replace(/-/g,'');
}
function paras(v){
  if(!v) return [];
  if(Array.isArray(v)) return v.flatMap(paras).filter(Boolean);
  if(isObj(v)) return Object.values(v).flatMap(paras).filter(Boolean);
  return String(v).split(/\n{2,}|\n/).map(x=>x.trim()).filter(Boolean);
}
function listify(v){
  if(!v) return [];
  if(Array.isArray(v)) return v.map(x => isObj(x) ? Object.values(x).join(' ') : String(x)).filter(Boolean);
  if(isObj(v)) return Object.entries(v).map(([k,val]) => `${k}: ${isObj(val) ? Object.values(val).join(' ') : val}`);
  return paras(v);
}
function pick(obj, keys, fallback=''){
  if(!obj) return fallback;
  for(const k of keys){
    if(obj[k] !== undefined && obj[k] !== null && obj[k] !== '') return obj[k];
  }
  return fallback;
}
function elementName(k){
  const s = String(k || '').toLowerCase();
  if(s.includes('목') || s.includes('wood')) return '목(木)';
  if(s.includes('화') || s.includes('fire')) return '화(火)';
  if(s.includes('토') || s.includes('earth')) return '토(土)';
  if(s.includes('금') || s.includes('metal')) return '금(金)';
  if(s.includes('수') || s.includes('water')) return '수(水)';
  return String(k || '');
}
function normalizeElements(v){
  const out = {'목(木)':0,'화(火)':0,'토(土)':0,'금(金)':0,'수(水)':0};
  if(!v) return out;

  if(typeof v === 'string'){
    const re = /(목|화|토|금|수|wood|fire|earth|metal|water)\s*(?:\([^)]+\))?\s*[:：]?\s*\(?\s*(\d+)/gi;
    let m;
    while((m = re.exec(v))){
      out[elementName(m[1])] = Number(m[2]) || 0;
    }
    return out;
  }

  if(isObj(v)){
    Object.entries(v).forEach(([k,val]) => {
      out[elementName(k)] = Number(val) || 0;
    });
  }
  return out;
}
function dominantFrom(elements, fallback){
  if(fallback){
    if(Array.isArray(fallback) && fallback.length) return elementName(fallback[0]);
    return elementName(fallback);
  }
  return Object.entries(elements).sort((a,b)=>(b[1]||0)-(a[1]||0))[0]?.[0] || '';
}
function stepText(step){
  return pick(step, ['text','instruction','body','description','content','practice','guide','action','message'], '');
}
function normalizeSteps(arr){
  if(!arr) return null;
  if(Array.isArray(arr)){
    return arr.map((s,i)=>{
      if(isObj(s)){
        return {
          label: pick(s, ['label','name','title','step'], String(i+1)),
          text: stepText(s)
        };
      }
      return {label:String(i+1), text:String(s)};
    });
  }
  if(isObj(arr)){
    return Object.entries(arr).map(([k,v]) => ({
      label:k,
      text:isObj(v) ? stepText(v) || Object.values(v).join(' / ') : String(v)
    }));
  }
  return null;
}
function makeSection(no,title,opts={}){
  return {
    no, title,
    headline: opts.headline || '',
    body: paras(opts.body),
    lists: opts.lists || null,
    steps: opts.steps ? normalizeSteps(opts.steps) : null,
    keyMessage: opts.keyMessage || '',
    insight: opts.insight || '',
    saju: opts.saju || null
  };
}
function osSteps(os){
  if(!os) return null;
  const keys = ['fiveSenseInput','sixthInterpretation','seventhIdentification','eighthStorage','ninthConsciousChoice'];
  return keys.filter(k=>os[k]).map(k=>({
    label: os[k].label || k,
    text: [os[k].description, os[k].clientPattern, os[k].choicePoint].filter(Boolean).join(' ')
  }));
}

