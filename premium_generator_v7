  }));

  sections.push(makeSection('05', os.title || '의식OS 구조 분석', {
    steps: osSteps(os),
    keyMessage: os.coreInsight || '',
    insight: os.calInsight || ''
  }));

  sections.push(makeSection('06', material.title || '현실은 어떻게 물질화되는가', {
    headline: Array.isArray(material.materializationDiagram) ? material.materializationDiagram.join(' → ') : '',
    steps: [
      {label:'반복 해석', text:material.innerPattern},
      {label:'반복 감정', text:material.repeatedEmotion},
      {label:'반복 선택', text:material.repeatedChoice},
      {label:'반복 행동', text:material.repeatedBehavior},
      {label:'현실 출력', text:material.outerResult}
    ].filter(s=>s.text),
    keyMessage: material.coreInsight || '',
    insight: material.calInsight || ''
  }));

  sections.push(makeSection('07', choice.title || '9식 — 관리자 권한 회복', {
    body: [
      choice.notSelfStatement,
      choice.observerStatement,
      choice.pausePoint,
