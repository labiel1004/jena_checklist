      disclaimer: isObj(raw.disclaimer) ? raw.disclaimer.text : (raw.disclaimer || '')
    };
  }

  return v4ToV7(raw);
}

async function fetchTemplate(){
  let lastError = '';
  for(const path of TEMPLATE_PATHS){
    try{
      const res = await fetch(path + '?v=' + Date.now(), {cache:'no-store'});
      if(res.ok){
        const text = await res.text();
        if(text.includes('window.REPORT_DATA')){
          $('templateStatus').innerHTML = `템플릿 연결됨: <code>${escapeHtml(path)}</code>`;
          return {text, path};
        }
        lastError = `${path} 파일 안에 window.REPORT_DATA가 없습니다.`;
      }else{
        lastError = `${path} 없음 (${res.status})`;
      }
    }catch(e){lastError=e.message;}
  }
  throw new Error('최종 템플릿 파일을 찾지 못했습니다. 마지막 오류: ' + lastError);
}

function injectDataIntoTemplate(templateHtml, data){
  const json = JSON.stringify(data, null, 2).replace(/<\//g, '<\\/');

  const re1 = /window\.REPORT_DATA\s*=\s*[\s\S]*?;\s*(?:const|let|var)\s+data\s*=\s*window\.REPORT_DATA\s*;/;
  if(re1.test(templateHtml)){
    return templateHtml.replace(re1, `window.REPORT_DATA = ${json};\nconst data = window.REPORT_DATA;`);
  }

  const re2 = /window\.REPORT_DATA\s*=\s*[\s\S]*?;\s*(?=\n|<\/script>)/;
  if(re2.test(templateHtml)){
    let replaced = templateHtml.replace(re2, `window.REPORT_DATA = ${json};\n`);
    if(!/(?:const|let|var)\s+data\s*=\s*window\.REPORT_DATA\s*;/.test(replaced)){
      replaced = replaced.replace(/window\.REPORT_DATA\s*=\s*[\s\S]*?;\n/, `window.REPORT_DATA = ${json};\nconst data = window.REPORT_DATA;\n`);
    }
    return replaced;
  }

  throw new Error('템플릿에서 window.REPORT_DATA 위치를 찾지 못했습니다.');
}

async function generate(){
  const box = $('msg');
  box.innerHTML = '생성 중...';
  try{
    const raw = $('jsonInput').value.trim();
    if(!raw) throw new Error('JSON이 비어 있습니다.');

    const parsed = JSON.parse(raw);
    const data = normalizeData(parsed);
    const {text:templateHtml, path:templatePath} = await fetchTemplate();
    const reportHtml = injectDataIntoTemplate(templateHtml, data);

    const filename = `report_${safeName(data.clientName)}_${dateDigits(data.reportDate)}.html`;
    const blob = new Blob([reportHtml], {type:'text/html;charset=utf-8'});
    const url = URL.createObjectURL(blob);

    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    a.click();

    const githubUrl = `https://labiel1004.github.io/jena_checklist/report_premium/${encodeURIComponent(filename)}`;

    box.innerHTML = `
      <div class="ok">생성 성공!</div>
      <div>인식된 고객명: <code>${escapeHtml(data.clientName)}</code></div>
      <div>인식된 날짜: <code>${escapeHtml(data.reportDate)}</code></div>
      <div>사주 오행: <code>${escapeHtml(JSON.stringify(data.sections.find(s=>s.no==='04')?.saju?.elements || {}))}</code></div>
      <div>8번 단계 수: <code>${escapeHtml((data.sections.find(s=>s.no==='08')?.steps || []).length)}</code></div>
      <div>사용 템플릿: <code>${escapeHtml(templatePath)}</code></div>
      <div>파일명: <code>${escapeHtml(filename)}</code></div>
      <div class="result-actions">
        <a class="btn" href="${url}" target="_blank" rel="noopener">바로 열어보기 ↗</a>
        <a class="btn light" href="${githubUrl}" target="_blank" rel="noopener">업로드 후 링크 ↗</a>
      </div>
      <div class="small">바로 열어보기에서 사주 04번과 재프로그래밍 08번을 확인한 뒤 업로드하세요.</div>
      <details class="small"><summary>변환된 v7 JSON 확인</summary><pre>${escapeHtml(JSON.stringify(data,null,2))}</pre></details>
    `;
  }catch(e){
    box.innerHTML = `<span class="err">생성 실패:</span> ${escapeHtml(e.message)}`;
  }
}

$('generateBtn').addEventListener('click', generate);
$('sampleBtn').addEventListener('click', ()=>{$('jsonInput').value = JSON.stringify(SAMPLE,null,2); $('msg').innerHTML='샘플을 불러왔습니다.';});
$('clearBtn').addEventListener('click', ()=>{$('jsonInput').value=''; $('msg').innerHTML='비웠습니다.';});

fetchTemplate().catch(e => {
  $('templateStatus').innerHTML = `<span class="err">템플릿 미연결:</span> ${escapeHtml(e.message)}`;
});
</script>
</body>
</html>
