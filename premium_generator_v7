function normalizeData(raw){
  if(raw.meta || raw.executiveSummary || raw.sajuLens || raw.reprogrammingProtocol){
    return v4ToV7(raw);
  }

  if(Array.isArray(raw.sections) && raw.sections.length){
    return {
      ...raw,
      clientName: raw.clientName || raw.name || raw.customerName || '고객',
      reportDate: raw.reportDate || raw.date || new Date().toISOString().slice(0,10),
      reportVersion: raw.reportVersion || 'CAL v7.0',
      heroSubtitle: raw.heroSubtitle || `${raw.clientName || raw.name || raw.customerName || '고객'}님의 현실 출력 구조 분석`,
